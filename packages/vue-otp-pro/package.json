{
  "name": "vue-otp-pro",
  "version": "1.0.0",
  "description": "A beautiful, customizable OTP input component for Vue 3 with built-in themes and animations",
  "keywords": ["vue", "vue3", "otp", "input", "verification", "pin", "code"],
  "license": "MIT",
  "author": "Pratik Patel",
  "type": "module",
  "main": "./dist/vue-otp-pro.umd.cjs",
  "module": "./dist/vue-otp-pro.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-otp-pro.js",
      "require": "./dist/vue-otp-pro.umd.cjs"
    },
    "./dist/vue-otp-pro.css": "./dist/vue-otp-pro.css"
  },
  "files": ["dist"],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build --force && vite build",
    "test:unit": "vitest",
    "type-check": "vue-tsc --build --force"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "~5.7.0",
    "vite": "^6.2.4",
    "vite-plugin-dts": "^4.5.3",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8"
  }
}
